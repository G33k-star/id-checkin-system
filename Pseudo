This program implements a Raspberry Pi-based student check-in system using
a magnetic stripe ID card scanner.

The system automatically generates two CSV files:
1) A student database file containing:
   [Name, Card ID, Student ID, Phone Number]

2) A daily check-in log containing:
   [Name, Card ID, Student ID, Phone Number, Timestamp]

The program records which students have checked in for the day and prevents
duplicate check-ins from the same user.

A new check-in log file is automatically created each day at 3:00 AM
Eastern Time, allowing the system to maintain separate daily attendance
records.

The program displays a disclaimer before prompting the user to swipe
their ID card.

During a scan, the system extracts the student's name and card ID from
the magnetic stripe data, verifies whether the student already exists in
the database, and logs their attendance accordingly.



BEGIN PROGRAM

    SET DATABASE_FILE = "database.csv"
    SET CHECKIN_FOLDER = "checkin_logs"
    SET DISCLAIMER = "By scanning your ID, you agree to the terms and conditions."

    IF CHECKIN_FOLDER does not exist THEN
        CREATE CHECKIN_FOLDER
    END IF


    FUNCTION create_database_if_needed
        IF DATABASE_FILE does not exist THEN
            CREATE database.csv
            WRITE header row:
                Name, Card ID, Student ID, Phone Number
        END IF
    END FUNCTION


    FUNCTION get_today_checkin_file
        GET current date
        FORMAT date as YYYY-MM-DD
        RETURN "checkin_logs/checkin_YYYY-MM-DD.csv"
    END FUNCTION


    FUNCTION create_checkin_file_if_needed(filename)
        IF filename does not exist THEN
            CREATE filename
            WRITE header row:
                Name, Card ID, Student ID, Phone Number, Timestamp
        END IF
    END FUNCTION


    FUNCTION parse_swipe(swipe)
        REMOVE leading and trailing spaces from swipe

        IF swipe does not contain "^" THEN
            RAISE error "Swipe data missing separators"
        END IF

        SPLIT swipe using "^"

        IF split result has fewer than 2 parts THEN
            RAISE error "Swipe data incomplete"
        END IF

        SET card_part = first part
        REMOVE spaces from card_part

        IF card_part does not start with "%B" THEN
            RAISE error "Missing Track 1 start"
        END IF

        REMOVE "%B" from card_part
        STORE result as card_id

        SET name_raw = second part
        REMOVE spaces from name_raw

        IF name_raw does not contain "/" THEN
            RAISE error "Invalid name format"
        END IF

        SPLIT name_raw using "/"

        IF split result has fewer than 2 parts THEN
            RAISE error "Incomplete name format"
        END IF

        SET last = first name part
        SET first = second name part

        CLEAN extra spaces inside first and last names

        SET formatted_name = first + " " + last

        RETURN formatted_name and card_id
    END FUNCTION


    FUNCTION valid_student_id(student_id)
        RETURN TRUE if student_id is all digits AND length is 10
        OTHERWISE RETURN FALSE
    END FUNCTION


    FUNCTION valid_phone_number(phone)
        REMOVE all non-digit characters from phone
        RETURN TRUE if remaining digits length is 10
        OTHERWISE RETURN FALSE
    END FUNCTION


    FUNCTION normalize_phone_number(phone)
        REMOVE all non-digit characters from phone
        RETURN cleaned phone number
    END FUNCTION


    FUNCTION find_student_in_database(card_id)
        IF DATABASE_FILE does not exist THEN
            RETURN NONE
        END IF

        OPEN DATABASE_FILE for reading

        FOR each row in database.csv
            IF row Card ID equals card_id THEN
                RETURN row
            END IF
        END FOR

        RETURN NONE
    END FUNCTION


    FUNCTION add_student_to_database(name, card_id, student_id, phone_number)
        OPEN DATABASE_FILE for appending
        WRITE:
            name, card_id, student_id, phone_number
    END FUNCTION


    FUNCTION already_checked_in_today(filename, card_id)
        IF filename does not exist THEN
            RETURN FALSE
        END IF

        OPEN filename for reading

        FOR each row in check-in file
            IF row Card ID equals card_id THEN
                RETURN TRUE
            END IF
        END FOR

        RETURN FALSE
    END FUNCTION


    FUNCTION save_checkin(filename, name, card_id, student_id, phone_number)
        GET current date and time
        FORMAT timestamp

        OPEN filename for appending
        WRITE:
            name, card_id, student_id, phone_number, timestamp
    END FUNCTION


    FUNCTION main
        CALL create_database_if_needed

        LOOP forever

            DISPLAY blank line
            DISPLAY DISCLAIMER
            DISPLAY "Please swipe your card."
            DISPLAY blank line

            GET swipe input

            IF swipe equals "exit" THEN
                DISPLAY "Program ended."
                STOP loop
            END IF

            IF swipe is empty THEN
                DISPLAY "No swipe detected. Please try again."
                CONTINUE loop
            END IF

            TRY
                CALL parse_swipe(swipe)
                STORE returned values as name and card_id
            CATCH parsing error
                DISPLAY "Invalid swipe format. Please try again."
                DISPLAY debug error information
                CONTINUE loop
            END TRY

            SET checkin_file = get_today_checkin_file()
            CALL create_checkin_file_if_needed(checkin_file)

            IF already_checked_in_today(checkin_file, card_id) is TRUE THEN
                DISPLAY "[name] has already checked in today. Entry ignored."
                CONTINUE loop
            END IF

            SET student = find_student_in_database(card_id)

            IF student exists THEN
                DISPLAY blank line
                DISPLAY "Student found in database:"
                DISPLAY student Name
                DISPLAY student Card ID
                DISPLAY student Student ID
                DISPLAY student Phone Number

                CALL save_checkin(
                    checkin_file,
                    student Name,
                    student Card ID,
                    student Student ID,
                    student Phone Number
                )

                DISPLAY "Check-in saved successfully."

            ELSE
                DISPLAY blank line
                DISPLAY "Hello, [name]. You are not in the database yet."
                DISPLAY "Please enter your Student ID and Phone Number."

                GET student_id input

                WHILE valid_student_id(student_id) is FALSE
                    DISPLAY "Invalid Student ID. It must be exactly 10 digits."
                    GET student_id input again
                END WHILE

                GET phone_number input

                WHILE valid_phone_number(phone_number) is FALSE
                    DISPLAY "Invalid phone number. It must contain exactly 10 digits."
                    GET phone_number input again
                END WHILE

                SET phone_number = normalize_phone_number(phone_number)

                CALL add_student_to_database(name, card_id, student_id, phone_number)
                CALL save_checkin(checkin_file, name, card_id, student_id, phone_number)

                DISPLAY "New student added to database."
                DISPLAY "Check-in saved successfully."
            END IF

        END LOOP
    END FUNCTION


    CALL main

END PROGRAM